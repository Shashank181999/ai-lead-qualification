# AI Lead Qualification System - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# LLM provider: "groq" (recommended - FREE)
LLM_PROVIDER=groq

# Groq API Key (FREE)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Connection String (FREE with Supabase)
# Get from: https://supabase.com -> Your Project -> Connect -> Session Pooler
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# =============================================================================
# FILE PATHS
# =============================================================================
INPUT_CSV_PATH=sample_leads.csv
OUTPUT_CSV_PATH=qualified_leads.csv
