# AI Lead Qualification System - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Choose your LLM provider: "openai", "anthropic", or "groq"
LLM_PROVIDER=openai

# OpenAI API Key (required if LLM_PROVIDER=openai)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (required if LLM_PROVIDER=anthropic)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Groq API Key (required if LLM_PROVIDER=groq)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# =============================================================================
# GOOGLE SHEETS CONFIGURATION (Optional)
# =============================================================================
# Path to your Google Cloud service account credentials JSON file
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# Name for the Google Sheet to create/update
GOOGLE_SHEET_NAME=Lead Qualification Results

# =============================================================================
# FILE PATHS
# =============================================================================
# Input CSV file with leads
INPUT_CSV_PATH=sample_leads.csv

# Output CSV file for qualified leads
OUTPUT_CSV_PATH=qualified_leads.csv
